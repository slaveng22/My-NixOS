{
    "height": 30,
    "spacing": 10,

    "modules-left": ["sway/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "custom/wlsunset", "network", "pulseaudio", "temperature", "battery"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%d-%b-%Y}",
        "tooltip-format": "<tt><big>{calendar}</big></tt>"
    },

    "tray": {
        "spacing": 8
    },

    "custom/wlsunset": {
        "exec": "if pgrep wlsunset > /dev/null; then echo 'ΎΗΗ'; else echo 'ΎΗΖ'; fi",
        "on-click": "if pgrep wlsunset > /dev/null; then systemctl --user stop wlsunset; else systemctl --user start wlsunset; fi",
        "interval": 5,
        "tooltip-format": "nightlight" 
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon} ΎΛΦ {format_source}",
        "format-bluetooth-muted": "{icon} ΎΛΦ {format_source}",
        "format-muted": "≤░ζθ {format_source}",
        "format-source": "ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΑξ",
            "headset": "ΎΑξ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },

    "network": {
        "format-wifi": "ΎΘτ ",
        "format-ethernet": "≤░ΙΑ ",
        "tooltip-format": "{essid}",
        "format-linked": "{ifname} (No IP) ≤░ΙΓ ",
        "format-disconnected": "Disconnected έγι ",
        "format-alt": "{ifname}: {ipaddr}"
    },

    "temperature": {
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["ΎΜΜ", "ΎΜΚ", "ΎΜΘ"],
        "critical-threshold": 80
    },

    "battery": {
        "states": {
            "good": 80,
            "warning": 50,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ≤░ΓΕ",
        "format-plugged": "{capacity}% ≤░ΓΔ",
        "format-alt": "{time} {icon}",
        "format-icons": ["≤░Β║", "≤░Β╝", "≤░Β╛", "≤░ΓΒ", "≤░Β╣"]
    }
}
