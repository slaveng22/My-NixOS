// Place your key bindings in this file to override the defaults
[
    {
        "key": "ctrl+alt+v",
        "command": "-workbench.action.editorDictation.start",
        "when": "hasSpeechProvider && !editorReadonly && !speechToTextInProgress"
    },
    {
        "key": "ctrl+alt+v",
        "command": "toggleVim"
    },
    {
        "key": "h",
        "command": "editor.action.scrollLeftHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "j",
        "command": "editor.action.scrollDownHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "k",
        "command": "editor.action.scrollUpHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "l",
        "command": "editor.action.scrollRightHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "shift+;",
        "command": "vim.showQuickpickCmdLine",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    // New file in Explorer
    {
        "key": "a",
        "command": "explorer.newFile",
        "when": "explorerViewletVisible && listFocus && !inputFocus"
    },
    // New folder in Explorer
    {
        "key": "shift+a",
        "command": "explorer.newFolder",
        "when": "explorerViewletVisible && listFocus && !inputFocus"
    },
    // Delete selected file/folder
    {
        "key": "d",
        "command": "deleteFile",
        "when": "explorerViewletVisible && listFocus && !inputFocus"
    },
    // Open to the side (split)
    {
        "key": "o",
        "command": "explorer.openToSide",
        "when": "explorerViewletVisible && listFocus && !inputFocus"
    },
    // Rename
    {
        "key": "r",
        "command": "renameFile",
        "when": "explorerViewletVisible && listFocus && !inputFocus"
    }
]