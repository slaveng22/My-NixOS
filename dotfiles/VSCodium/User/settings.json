{
    "workbench.colorTheme": "Gruvbox Dark Hard",
    "breadcrumbs.enabled": false,
    "window.zoomLevel": 2,
    "explorer.compactFolders": false,
    "editor.lineNumbers": "relative",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.minimap.enabled": false,
    "editor.smoothScrolling": true,
    "editor.stickyScroll.enabled": false, //Fixes scroll lag
    "editor.cursorSurroundingLines": 5,
    "editor.fontFamily": "'JetBrainsMono NF Thin'",
    "editor.fontLigatures": true,
    "editor.fontSize": 16,
    "editor.renderer": "default",
    "terminal.integrated.fontFamily": "'JetBrainsMono NF Thin'",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.gpuAcceleration": "on",
    "terminal.integrated.suggest.enabled": false,
    "zenMode.hideLineNumbers": false,
    "vim.leader": "<Space>",
    "vim.changeWordIncludesWhitespace": true,
    "vim.smartRelativeLine": true, // Makes line numbers relative only in normal mode
    "vim.useSystemClipboard": true, // Enables vim to use system clipboard
    "vim.hlsearch": true, // Highlight search results
    "vim.ignorecase": true, // Disables case sensitive search
    "vim.smartcase": true, // Enables case sensitive search if uppercase letters are used
    "vim.visualstar": true, // Allows * and # to work in visual mode (seek next and previous occurrence of selected text)
    "vim.highlightedyank.enable": true,
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": ["g", "O"],
            "commands": ["editor.action.insertLineBefore"]
        },
        {
            "before": ["g", "o"],
            "commands": ["editor.action.insertLineAfter"]
        },
         // splits
        {
            "before": ["leader", "v"],
            "commands": [":vsplit"]
        },
        {
            "before": ["leader", "s"],
            "commands": [":split"]
        },
        // Move between splits
        {
            "before": ["leader", "h"],
            "commands": ["workbench.action.focusLeftGroup"]
        },
        {
            "before": ["leader", "j"],
            "commands": ["workbench.action.focusBelowGroup"]
        },
        {
            "before": ["leader", "k"],
            "commands": ["workbench.action.focusAboveGroup"]
        },
        {
            "before": ["leader", "l"],
            "commands": ["workbench.action.focusRightGroup"]
        },
        // Move between tabs
        {
            "before": ["H"],
            "commands": ["workbench.action.previousEditor"]
        },
        {
            "before": ["L"],
            "commands": ["workbench.action.nextEditor"]
        },
        // SAVE, QUIT AND QUIT AND SAVE
        {
            "before": ["leader", "w"],
            "commands": [":w!"]
        },
        {
            "before": ["leader", "q"],
            "commands": [":q!"]
        },
        {
            "before": ["leader", "x"],
            "commands": [":x!"]
        },
        // LSP
        {
            "before": ["<leader>", "c", "a"],
            "commands": ["editor.action.quickFix"]
        },
        {
            "before": ["g", "p", "d"],
            "commands": ["editor.action.peekDefinition"]
        },
        {
            "before": ["g", "h"],
            "commands": ["editor.action.showDefinitionPreviewHover"]
        },
        {
            "before": ["g", "i"],
            "commands": ["editor.action.goToImplementation"]
        },
        {
            "before": ["g", "p", "i"],
            "commands": ["editor.action.peekImplementation"]
        },
        {
            "before": ["g", "r"],
            "commands": ["editor.action.referenceSearch.trigger"]
        },
        {
            "before": ["g", "t"],
            "commands": ["editor.action.goToTypeDefinition"]
        },
        {
            "before": ["g", "p", "t"],
            "commands": ["editor.action.peekTypeDefinition"]
        },
        // Clear higlighted search results
        {
            "before": ["<leader>", "n"],
            "commands": [":noh"]
        },
        // Open terminal
        {
            "before": ["<leader>", "t"],
            "commands": ["workbench.action.terminal.toggleTerminal"]
        },
        // Quick Open files (Ctrl+P)
        {
            "before": ["<leader>", "p"],
            "commands": ["workbench.action.quickOpen"]
        },
        // Toggle search
        {
            "before": ["<leader>", "f"],
            "commands": ["actions.find"]
        },
        // Global search (Ctrl+Shift+F)
        {
            "before": ["<leader>", "F"],
            "commands": ["workbench.view.search"]
        },
        // Search and replace (Ctrl+Shift+H)
        {
            "before": ["<leader>", "r"],
            "commands": ["editor.action.startFindReplaceAction"]
        },
        // Global search and replace (Ctrl+Shift+H)
        {
            "before": ["<leader>", "R"],
            "commands": ["workbench.action.replaceInFiles"]
        },
       ],
    "vim.visualModeKeyBindings": [
        // Stay in visual mode while indenting
        {
            "before": ["<"],
            "commands": ["editor.action.outdentLines"]
        },
        {
            "before": [">"],
            "commands": ["editor.action.indentLines"]
        },
        // Move selected lines while staying in visual mode
        {
            "before": ["J"],
            "commands": ["editor.action.moveLinesDownAction"]
        },
        {
            "before": ["K"],
            "commands": ["editor.action.moveLinesUpAction"]
        }
    ],
    "vim.handleKeys": {
    "<C-p>": false,        // Quick Open
    "<C-b>": false,        // Toggle Sidebar
    "<C-f>": false,        // Find
    "<C-h>": false,        // Replace
    "<C-`>": false,        // Terminal
    "<C-j>": false,        // Bottom Panel
    "<C-o>": false,        // Open file
    "<C-k>": false,        // CTRL+K shortcuts
    },
    // Increase affinity for the Vim extension (makes it more responsive)
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    },
    "git.autofetch": true,
    "redhat.telemetry.enabled": true,
    "python.defaultInterpreterPath": "c:\\Users\\gug\\AppData\\Local\\Programs\\Python\\Python39\\python.exe",
    "workbench.iconTheme": "material-icon-theme",
    "containers.containerClient": "com.microsoft.visualstudio.containers.podman",
    "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.podmancompose",
    "supermaven.enable": {
        "*": false
    },
    "window.menuBarVisibility": "compact",
    "window.commandCenter": false,
    "workbench.activityBar.location": "top",
    "harper.dialect": "American",
}